# Copy to .env and fill in. .env is gitignored.

# --- OpenAI ---
# Used for Whisper transcription and text-embedding-3-small (transcript embeddings + query embedding).
OPENAI_API_KEY=sk-...

# --- Qdrant Cloud ---
QDRANT_URL=https://your-cluster.us-west-2-0.aws.cloud.qdrant.io
QDRANT_API_KEY=...

# --- Neon Postgres (auto-provisioned via Vercel Marketplace) ---
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# --- Upstash Redis (auto-provisioned via Vercel Marketplace) ---
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# --- Vercel Blob (auto-provisioned when Blob store is created) ---
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# --- App config ---
NEXT_PUBLIC_APP_NAME="Long-form video search"
SEARCH_RATE_LIMIT_PER_MIN=30
SEARCH_DAILY_GLOBAL_CAP=10000

# Optional: gate the MCP endpoint with a bearer token. Leave empty for public access.
MCP_TOKEN=

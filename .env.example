# Copy to .env and fill in. .env is gitignored.

# --- OpenAI ---
# Used for text-embedding-3-small (transcript + query embeddings) and the
# residual gpt-4o-mini calls (attendee-context extraction, fallback Alex/attendee
# speaker labeling when no reference clip is supplied).
OPENAI_API_KEY=sk-...

# --- Deepgram (audio transcription + diarization) ---
# Replaces Whisper. Word-level timestamps + per-word speaker labels.
DEEPGRAM_API_KEY=...

# --- Reference clip for voice fingerprinting ---
# Absolute path to a short (~10s+) clip of the main speaker (Alex) talking solo.
# Resemblyzer compares each Deepgram speaker cluster against this and tags
# whichever matches as "alex". Other clusters become "attendee".
# If unset, fallback: LLM examines per-cluster text and assigns the role.
ALEX_REFERENCE_AUDIO=

# --- Qdrant Cloud ---
QDRANT_URL=https://your-cluster.us-west-2-0.aws.cloud.qdrant.io
QDRANT_API_KEY=...

# --- Neon Postgres (auto-provisioned via Vercel Marketplace) ---
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# --- Upstash Redis (auto-provisioned via Vercel Marketplace) ---
# The web app reads these via the Vercel KV-standard names (KV_REST_API_URL /
# KV_REST_API_TOKEN). Vercel sets both automatically when a KV store is
# attached. If you provisioned Upstash directly, alias accordingly.
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=...

# --- Vercel Blob (auto-provisioned when Blob store is created) ---
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# --- App config ---
NEXT_PUBLIC_APP_NAME="Long-form video search"
SEARCH_RATE_LIMIT_PER_MIN=30
SEARCH_DAILY_GLOBAL_CAP=10000

# Optional: gate the MCP endpoint with a bearer token. Leave empty for public access.
MCP_TOKEN=

# --- Demo gate ---
# Shared password presented after an anonymous IP exhausts its 5 free
# searches per 24h. The /api/login route sets a cookie ("demo_auth") whose
# value is the literal password; authenticated requests bypass the IP gate
# entirely. Leave empty to disable the gate (everything stays anonymous).
DEMO_PASSWORD=

# Hard daily ceiling on LLM + embedding spend for /api/search/sessions. When
# the rolling 24h sum exceeds this, the endpoint returns 429.
DAILY_COST_CEILING_USD=5

# --- Dev/internal routes ---
# Gates /eval (golden-set dashboard), /v/[id] (raw moments debug page), and
# the /api/eval/*, /api/search, /api/search/sessions endpoints. Set to "1" in
# .env.local to enable locally. Leave UNSET in production deployments — the
# main /demo page does not depend on any of these routes.
ENABLE_DEV_ROUTES=
